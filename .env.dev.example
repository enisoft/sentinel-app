# Copie para .env.dev e preencha com valores do ambiente local.
# Emulador Android: 10.0.2.2 = localhost do host.
# Dispositivo físico: IP da máquina na LAN ou Tailscale.

SUPABASE_URL=http://<ip-local>:55321
SUPABASE_ANON_KEY=
API_BASE_URL=http://<ip-tailscale>:8000/api/v1

# Dev: atraso artificial antes do upload TUS (segundos). 0 ou ausente = desligado.
SYNC_DEBUG_UPLOAD_DELAY_SECONDS=0

# Obter SUPABASE_ANON_KEY local:
#   cd sentinel-backend && npx supabase status -o env
