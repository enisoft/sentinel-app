# Copie para .env e preencha com valores locais.
# Emulador Android: 10.0.2.2 = localhost do host.
# Dispositivo físico: use o IP da máquina na LAN.

SUPABASE_URL=http://10.0.2.2:54321
SUPABASE_ANON_KEY=
API_BASE_URL=http://10.0.2.2:8000/api/v1

# Dev: atraso artificial antes do upload TUS (segundos). 0 ou ausente = desligado.
SYNC_DEBUG_UPLOAD_DELAY_SECONDS=0

# Obter SUPABASE_ANON_KEY:
#   cd sentinel-backend && npx supabase status -o env
