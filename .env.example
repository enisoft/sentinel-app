# Copie para .env e preencha com valores locais.
# Emulador Android: 10.0.2.2 = localhost do host.
# Dispositivo físico: use o IP da máquina na LAN.

SUPABASE_URL=http://10.0.2.2:54321
SUPABASE_ANON_KEY=
API_BASE_URL=http://10.0.2.2:8000/api/v1

# Dev: atraso artificial antes do upload TUS (segundos). 0 ou ausente = desligado.
SYNC_DEBUG_UPLOAD_DELAY_SECONDS=0

# ENI-105: sem progresso/bytes TUS por N segundos → aborta upload (padrão 25).
TUS_UPLOAD_STALL_TIMEOUT_SECONDS=25

# ENI-105: teto de duração de um ciclo de drain de sync em minutos (padrão 30).
SYNC_DRAIN_CYCLE_TIMEOUT_MINUTES=30

# ENI-105: timeout do primeiro contato HTTP — GET /me, POST /occurrences/sync (padrão 10s).
SYNC_INITIAL_CONTACT_TIMEOUT_SECONDS=10

# ENI-105: backoff entre tentativas de primeiro contato (padrão 3s).
SYNC_INITIAL_CONTACT_RETRY_BACKOFF_SECONDS=3

# Obter SUPABASE_ANON_KEY:
#   cd sentinel-backend && npx supabase status -o env
